{
  "compilerOptions": {
    "target": "ES2020",                // Modern JavaScript output
    "module": "commonjs",              // Node.js module system
    "strict": true,                     // Enable strict type checks
    "esModuleInterop": true,           // Allows 'import express from "express"'
    "skipLibCheck": true,              // Skip type checking of node_modules
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"                  // Compiled JS files go here
  },
  "include": ["**/*.ts"]
}
